# cadkit / onshape-mcp credentials. Copy to `.env` and fill in.
# Two auth modes are supported; cadkit prefers OAuth when a token is present.

# ── Mode 1: API key (default; simplest, fully headless) ──────────────────────
# Generate at https://dev.onshape.com -> API keys. These calls COUNT against the
# 2,500/yr quota and act as you.
ONSHAPE_ACCESS_KEY=
ONSHAPE_SECRET_KEY=

# ── Mode 2: OAuth2 (bring-your-own-account; run `cadkit-auth login`) ─────────
# Register a "Connected desktop app" in the Onshape dev portal (OAuth application)
# with the redirect URI below, then run `cadkit-auth login`. Calls become exempt
# from the quota only once the app is PUBLISHED in the App Store; a private app
# still counts. Leave these blank to stay on API-key auth.
ONSHAPE_OAUTH_CLIENT_ID=
ONSHAPE_OAUTH_CLIENT_SECRET=
# Must exactly match the redirect URI registered for the app:
ONSHAPE_OAUTH_REDIRECT=http://localhost:8910/callback
# Optional overrides:
# ONSHAPE_OAUTH_SCOPE=OAuth2Read OAuth2Write OAuth2Delete
# ONSHAPE_OAUTH_TOKEN_PATH=~/.cadkit/onshape_token.json
# ONSHAPE_BASE_URL=https://cad.onshape.com
